// Bingoal — Prisma schema
// Data lives in Supabase Postgres. Auth identities live in Supabase `auth.users`;
// `Profile.id` mirrors that UUID. App-layer authorization is enforced in server
// actions/route handlers; Supabase RLS is added as defense-in-depth (see backlog).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// A user profile, keyed by the Supabase auth user id.
model Profile {
  id          String   @id @db.Uuid
  email       String?
  displayName String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cards       Card[]

  @@map("profiles")
}

/// How square content is laid out on the grid.
enum CardLayout {
  RANDOM // shuffled into a fixed layout once, at creation
  SET // placed in the order the user entered them
}

/// A single bingo card owned by a user.
model Card {
  id           String     @id @default(uuid()) @db.Uuid
  ownerId      String     @db.Uuid
  owner        Profile    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name         String
  gridSize     Int        @default(5) // 3 => 3x3, 5 => 5x5 (extensible later)
  hasFreeSpace Boolean    @default(true)
  layout       CardLayout @default(RANDOM)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  squares      Square[]

  @@index([ownerId])
  @@map("cards")
}

/// The kind of goal a square represents.
enum SquareKind {
  CHECK // one-and-done: complete it once
  COUNTER // reach a target count (e.g. "do 10 puzzles")
}

/// A single cell on a card. `goal` unifies both kinds: CHECK == goal 1,
/// COUNTER == goal N. A square is "complete" when its completion count >= goal
/// (or when it is the free space).
model Square {
  id          String       @id @default(uuid()) @db.Uuid
  cardId      String       @db.Uuid
  card        Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  position    Int // 0-based slot index in the grid; fixed once assigned
  label       String       @default("")
  kind        SquareKind   @default(CHECK)
  goal        Int          @default(1)
  isFreeSpace Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  completions Completion[]

  @@unique([cardId, position])
  @@index([cardId])
  @@map("squares")
}

/// One logged step toward a square's goal. CHECK squares have a single entry;
/// COUNTER squares get one entry per increment. `completedAt` defaults to now
/// but is user-editable. Future: attach a photo per completion.
model Completion {
  id          String   @id @default(uuid()) @db.Uuid
  squareId    String   @db.Uuid
  square      Square   @relation(fields: [squareId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())
  note        String?
  createdAt   DateTime @default(now())

  @@index([squareId])
  @@map("completions")
}
