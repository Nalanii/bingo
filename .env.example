# ---------------------------------------------------------------------------
# Bingoal environment variables
# Copy this file to `.env.local` and fill in the values.
# Never commit `.env.local` — it is gitignored.
# ---------------------------------------------------------------------------

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Database — Project Settings > Database > Connection string
# Use the pooled (transaction) connection for the app runtime (DATABASE_URL)
# and the direct connection for Prisma migrations (DIRECT_URL).
DATABASE_URL="postgresql://postgres.your-ref:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.your-ref:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# Base URL of the app (used for OAuth redirects). No trailing slash.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
